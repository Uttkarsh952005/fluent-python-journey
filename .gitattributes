# Git line ending normalization
# Ensures consistent LF line endings in repo, CRLF on Windows checkout

* text=auto

# Python files: LF in repo
*.py text eol=lf

# Markdown: LF in repo
*.md text eol=lf

# Config files: LF in repo
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files: no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
